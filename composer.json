{
    "name": "jack009/coming-soon-symfony-bundle",
    "description": "A Symfony bundle to enable or disable a Coming Soon page for your application.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "bundle", "coming-soon", "maintenance"],
    "authors": [
        {
            "name": "JACK009"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/dependency-injection": "^6.0|^7.0",
        "symfony/http-kernel": "^6.0|^7.0",
        "symfony/config": "^6.0|^7.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/http-foundation": "^6.0|^7.0",
        "symfony/event-dispatcher": "^6.0|^7.0",
        "symfony/framework-bundle": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Jack009\\ComingSoonBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jack009\\ComingSoonBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
